# Copy to eval_config.env and: source scripts/server/config/eval_config.env

# --- A800 80GB (recommended): vLLM + Qwen2.5-32B judge ---
export EVAL_BACKEND=vllm
export EVAL_BASE_URL=http://127.0.0.1:8000/v1
export EVAL_API_KEY=local
export EVAL_MODEL=Qwen/Qwen2.5-32B-Instruct
export EVAL_TEMPERATURE=0

# Skip Bing/Selenium during reasoning factuality check (Judge uses case summary only)
export EVAL_DISABLE_WEB_SEARCH=1

# --- Lighter / faster judge on same A800 ---
# export EVAL_MODEL=Qwen/Qwen2.5-14B-Instruct

# --- Ollama (no vLLM) ---
# export EVAL_BACKEND=ollama
# export EVAL_BASE_URL=http://127.0.0.1:11434/v1
